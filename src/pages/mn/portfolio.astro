---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Компани - Портфолио">
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h1 class="text-5xl font-display font-bold mb-4 bg-gradient-to-r from-orange-400 to-red-500 bg-clip-text text-transparent">
        Манай ажил
      </h1>
      <p class="text-xl text-zinc-400">
        Манай сүүлийн үеийн төслүүд
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="group cursor-pointer">
        <div class="aspect-video rounded-xl mb-4 overflow-hidden">
          <img 
            src={`/images/project1.jpg`} 
            alt="Project One" 
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
          />
        </div>
        <h3 class="text-xl font-display font-semibold mb-2">Туршилтын төсөл</h3>
        <p class="text-zinc-400">Байршил: Улаанбаатар хот</p>
      </div>

      <div class="group cursor-pointer">
        <div class="aspect-video bg-gradient-to-br from-blue-500/20 to-purple-500/20 rounded-xl mb-4 group-hover:scale-105 transition-transform"></div>
        <h3 class="text-xl font-display font-semibold mb-2">Төсөл хоёр</h3>
        <p class="text-zinc-400">Байршил: Хатанбулаг сум</p>
      </div>


    </div>
  </section>
</Layout>
