---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Company - About">
  <section class="max-w-4xl mx-auto px-6 py-24">
    <h1 class="text-5xl font-display font-bold mb-6 bg-gradient-to-r from-orange-400 to-red-500 bg-clip-text text-transparent">
      About Us
    </h1>
    <div class="prose prose-invert prose-lg max-w-none">
      <p class="text-xl text-zinc-400 leading-relaxed">
        We are a team of engineers dedicated to build sustainable heating infrastructure.
      </p>
      <p class="text-zinc-400 leading-relaxed mt-6">
        sparse Energy is a thermal energy storage company specializing in sand battery technology that
        provides sustainable heating solutions. Founded to address Mongolia’s energy challenges, we develop
        decentralized heating systems that free consumers from dependence on coal-fueled furnaces and
        centralized heating infrastructure.
      </p>
    </div>
  </section>
</Layout>
